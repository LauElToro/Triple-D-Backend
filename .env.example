# ---- Database ----
# Local: Postgres propio. Producción: Prisma Postgres / Vercel Postgres / Neon.
# DATABASE_URL es la única que consumen Prisma y la app; usar conexión DIRECTA
# (no pooler) para que `prisma migrate deploy` funcione en el build.
DATABASE_URL="postgresql://tripled:tripled@localhost:5432/tripled?schema=public"
# Opcionales: alias que setea la integración Prisma Postgres / Vercel.
POSTGRES_URL=""
PRISMA_DATABASE_URL=""

# ---- App URLs ----
API_URL="http://localhost:4000"
WEB_APP_URL="http://localhost:3000"

# ---- JWT / Sessions ----
JWT_ACCESS_SECRET="change-me-access-secret-32chars-min"
JWT_REFRESH_SECRET="change-me-refresh-secret-32chars-min"
ACCESS_TOKEN_TTL_SECONDS="7200"
REFRESH_TOKEN_TTL_SECONDS="1209600"

# ---- API Keys ----
API_KEY_PEPPER="change-me-api-key-pepper"

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"

# ---- Gmail (nodemailer) ----
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
MAIL_FROM="Triple D <no-reply@example.com>"

# ---- Didit KYC ----
DIDIT_API_KEY=""
DIDIT_WEBHOOK_SECRET=""
DIDIT_WORKFLOW_ID=""
DIDIT_BASE_URL="https://verification.didit.me"

# ---- ARCA gateway (FastAPI) ----
ARCA_BASE_URL="http://localhost:3000"
ARCA_API_KEY="dev-local-key"

# ---- Bootstrap SuperAdmin (seed) ----
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD=""
